{
  "name": "@kozmos-auth/auth",
  "version": "0.1.0",
  "description": "Kozmos client SDK — add email/password (and optional Google) auth to your Next.js or Hono app, backed by the hosted Kozmos service.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./client": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    }
  },
  "scripts": {
    "build": "tsup && node scripts/add-use-client.mjs",
    "dev": "tsup --watch --onSuccess \"node scripts/add-use-client.mjs\"",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.6.23"
  },
  "peerDependencies": {
    "hono": "^4.0.0",
    "next": "^15 || ^16",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kozmos-auth/typescript-config": "*",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.0",
    "hono": "^4.12.28",
    "next": "^16.2.10",
    "react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
