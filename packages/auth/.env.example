# @kozmos-auth/auth — client SDK config.
# Create a project in the Kozmos dashboard to obtain your keys.

# Client (browser-safe). Publishable key scopes requests to your project.
NEXT_PUBLIC_KOZMOS_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_KOZMOS_API_URL="http://localhost:3000"
# Optional — enables Google sign-in helpers.
NEXT_PUBLIC_KOZMOS_GOOGLE="false"

# Server (never exposed to the browser). Authorizes trusted session lookups.
KOZMOS_SECRET_KEY="sk_live_..."
KOZMOS_API_URL="http://localhost:3000"
