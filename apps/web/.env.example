# Postgres connection string (e.g. your Neon database URL)
DATABASE_URL=""

# Better Auth — server (used by the dashboard's auth instance in lib/auth.ts)
# A long random secret used to sign tokens (openssl rand -base64 32)
BETTER_AUTH_SECRET=""
# The base URL the app runs on
BETTER_AUTH_URL="http://localhost:3000"

# Better Auth — browser client (lib/auth-client.ts)
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# End-user auth service (lib/end-user/*, served at /api/kozmos/auth).
# Optional: enables Google sign-in for end-users when both are set.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
